@startuml
set separator none
title Espaces fonctionnels - ASHS Alumni

top to bottom direction
skinparam ranksep 60
skinparam nodesep 30

skinparam {
  arrowFontSize 10
  defaultTextAlignment center
  wrapWidth 200
  maxMessageSize 100
}

hide stereotype

skinparam person<<Administrateur>> {
  BackgroundColor #08427b
  FontColor #ffffff
  BorderColor #052e56
  shadowing false
}
skinparam rectangle<<ASHSAlumni.Administration>> {
  BackgroundColor #438dd5
  FontColor #ffffff
  BorderColor #2e6295
  roundCorner 20
  shadowing false
}
skinparam person<<AncienActuelJoueur>> {
  BackgroundColor #08427b
  FontColor #ffffff
  BorderColor #052e56
  shadowing false
}
skinparam rectangle<<ASHSAlumni.GestiondesContacts>> {
  BackgroundColor #438dd5
  FontColor #ffffff
  BorderColor #2e6295
  roundCorner 20
  shadowing false
}
skinparam rectangle<<ASHSAlumni.GestiondesUtilisateurs>> {
  BackgroundColor #438dd5
  FontColor #ffffff
  BorderColor #2e6295
  roundCorner 20
  shadowing false
}
skinparam rectangle<<ASHSAlumni.GestiondesÉvénements>> {
  BackgroundColor #438dd5
  FontColor #ffffff
  BorderColor #2e6295
  roundCorner 20
  shadowing false
}
skinparam rectangle<<ASHSAlumni.Historisation>> {
  BackgroundColor #438dd5
  FontColor #ffffff
  BorderColor #2e6295
  roundCorner 20
  shadowing false
}
skinparam person<<InvitéInscritSpontané>> {
  BackgroundColor #08427b
  FontColor #ffffff
  BorderColor #052e56
  shadowing false
}
skinparam rectangle<<ServiceSMS>> {
  BackgroundColor #999999
  FontColor #ffffff
  BorderColor #6b6b6b
  roundCorner 20
  shadowing false
}
skinparam rectangle<<ASHSAlumni>> {
  BorderColor #0b4884
  FontColor #0b4884
  shadowing false
}

person "==Ancien/Actuel Joueur\n<size:10>[Person]</size>\n\nMembre des équipes 1 de l'ASHS souhaitant participer aux retrouvailles" <<AncienActuelJoueur>> as AncienActuelJoueur
person "==Invité/Inscrit Spontané\n<size:10>[Person]</size>\n\nPersonne invitée ou s'inscrivant spontanément" <<InvitéInscritSpontané>> as InvitéInscritSpontané
person "==Administrateur\n<size:10>[Person]</size>\n\nGestionnaire de l'application avec droits étendus" <<Administrateur>> as Administrateur
rectangle "==Service SMS\n<size:10>[Software System]</size>\n\nService externe d'envoi de SMS pour les invitations" <<ServiceSMS>> as ServiceSMS

rectangle "ASHS Alumni\n<size:10>[Software System]</size>" <<ASHSAlumni>> {
  rectangle "==Gestion des Utilisateurs\n<size:10>[Container: Fonctionnel]</size>\n\nEspace de gestion des comptes d'accès et authentification" <<ASHSAlumni.GestiondesUtilisateurs>> as ASHSAlumni.GestiondesUtilisateurs
  rectangle "==Gestion des Événements\n<size:10>[Container: Fonctionnel]</size>\n\nEspace de gestion des soirées retrouvailles et inscriptions" <<ASHSAlumni.GestiondesÉvénements>> as ASHSAlumni.GestiondesÉvénements
  rectangle "==Administration\n<size:10>[Container: Fonctionnel]</size>\n\nEspace de gestion administrative et supervision" <<ASHSAlumni.Administration>> as ASHSAlumni.Administration
  rectangle "==Historisation\n<size:10>[Container: Fonctionnel]</size>\n\nEspace de traçabilité et conservation des historiques" <<ASHSAlumni.Historisation>> as ASHSAlumni.Historisation
  rectangle "==Gestion des Contacts\n<size:10>[Container: Fonctionnel]</size>\n\nEspace de gestion des informations personnelles et statuts des contacts" <<ASHSAlumni.GestiondesContacts>> as ASHSAlumni.GestiondesContacts
}

AncienActuelJoueur -[#707070,thickness=2]-> ASHSAlumni.GestiondesContacts : "<color:#707070>Ajoute et consulte les contacts"
AncienActuelJoueur -[#707070,thickness=2]-> ASHSAlumni.GestiondesÉvénements : "<color:#707070>Consulte et s'inscrit aux événements"
InvitéInscritSpontané -[#707070,thickness=2]-> ASHSAlumni.GestiondesContacts : "<color:#707070>Valide son contact"
Administrateur -[#707070,thickness=2]-> ASHSAlumni.GestiondesÉvénements : "<color:#707070>Définit les dates de soirée"
Administrateur -[#707070,thickness=2]-> ASHSAlumni.GestiondesContacts : "<color:#707070>Gère les contacts"
ASHSAlumni.GestiondesUtilisateurs -[#707070,thickness=2]-> ASHSAlumni.GestiondesContacts : "<color:#707070>Un utilisateur doit être associé à un contact validé"
ASHSAlumni.GestiondesContacts -[#707070,thickness=2]-> ASHSAlumni.GestiondesÉvénements : "<color:#707070>Seuls les contacts validés peuvent s'inscrire"
ASHSAlumni.GestiondesÉvénements -[#707070,thickness=2]-> ASHSAlumni.GestiondesUtilisateurs : "<color:#707070>Vérifie que l'utilisateur est associé à un contact validé"
ASHSAlumni.Administration -[#707070,thickness=2]-> ASHSAlumni.GestiondesContacts : "<color:#707070>Gestion complète des contacts"
ASHSAlumni.Administration -[#707070,thickness=2]-> ASHSAlumni.GestiondesÉvénements : "<color:#707070>Gestion des dates et inscriptions"
ASHSAlumni.Administration -[#707070,thickness=2]-> ASHSAlumni.GestiondesUtilisateurs : "<color:#707070>Gestion des droits d'accès"
ASHSAlumni.Historisation -[#707070,thickness=2]-> ASHSAlumni.GestiondesContacts : "<color:#707070>Trace toutes les modifications"
ASHSAlumni.Historisation -[#707070,thickness=2]-> ASHSAlumni.GestiondesÉvénements : "<color:#707070>Enregistre les inscriptions et événements"
ASHSAlumni.GestiondesContacts -[#707070,thickness=2]-> ServiceSMS : "<color:#707070>Déclenche l'envoi d'invitations"
ASHSAlumni.GestiondesContacts -[#707070,thickness=2]-> ASHSAlumni.GestiondesContacts : "<color:#707070>Processus interne de vérification"
@enduml