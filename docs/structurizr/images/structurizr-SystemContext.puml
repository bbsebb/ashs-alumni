@startuml
set separator none
title Diagramme de contexte - ASHS Alumni

top to bottom direction
skinparam ranksep 60
skinparam nodesep 30

skinparam {
  arrowFontSize 10
  defaultTextAlignment center
  wrapWidth 200
  maxMessageSize 100
}

hide stereotype

skinparam rectangle<<ASHSAlumni>> {
  BackgroundColor #1168bd
  FontColor #ffffff
  BorderColor #0b4884
  roundCorner 20
  shadowing false
}
skinparam person<<Administrateur>> {
  BackgroundColor #08427b
  FontColor #ffffff
  BorderColor #052e56
  shadowing false
}
skinparam person<<AncienActuelCoach>> {
  BackgroundColor #08427b
  FontColor #ffffff
  BorderColor #052e56
  shadowing false
}
skinparam person<<AncienActuelJoueur>> {
  BackgroundColor #08427b
  FontColor #ffffff
  BorderColor #052e56
  shadowing false
}
skinparam person<<AncienActuelPrésident>> {
  BackgroundColor #08427b
  FontColor #ffffff
  BorderColor #052e56
  shadowing false
}
skinparam person<<ContributeurActif>> {
  BackgroundColor #08427b
  FontColor #ffffff
  BorderColor #052e56
  shadowing false
}
skinparam person<<InvitéInscritSpontané>> {
  BackgroundColor #08427b
  FontColor #ffffff
  BorderColor #052e56
  shadowing false
}
skinparam rectangle<<ServiceSMS>> {
  BackgroundColor #999999
  FontColor #ffffff
  BorderColor #6b6b6b
  roundCorner 20
  shadowing false
}

person "==Ancien/Actuel Joueur\n<size:10>[Person]</size>\n\nMembre des équipes 1 de l'ASHS souhaitant participer aux retrouvailles" <<AncienActuelJoueur>> as AncienActuelJoueur
person "==Ancien/Actuel Coach\n<size:10>[Person]</size>\n\nEntraîneur des équipes 1 de l'ASHS" <<AncienActuelCoach>> as AncienActuelCoach
person "==Ancien/Actuel Président\n<size:10>[Person]</size>\n\nDirigeant de l'ASHS" <<AncienActuelPrésident>> as AncienActuelPrésident
person "==Contributeur Actif\n<size:10>[Person]</size>\n\nPersonne ayant contribué aux équipes 1 (table de marque, chauffeur, etc.)" <<ContributeurActif>> as ContributeurActif
person "==Invité/Inscrit Spontané\n<size:10>[Person]</size>\n\nPersonne invitée ou s'inscrivant spontanément" <<InvitéInscritSpontané>> as InvitéInscritSpontané
person "==Administrateur\n<size:10>[Person]</size>\n\nGestionnaire de l'application avec droits étendus" <<Administrateur>> as Administrateur
rectangle "==Service SMS\n<size:10>[Software System]</size>\n\nService externe d'envoi de SMS pour les invitations" <<ServiceSMS>> as ServiceSMS
rectangle "==ASHS Alumni\n<size:10>[Software System]</size>\n\nApplication web de gestion des retrouvailles des anciens membres" <<ASHSAlumni>> as ASHSAlumni

AncienActuelJoueur -[#707070,thickness=2]-> ASHSAlumni : "<color:#707070>Consulte les contacts, s'inscrit aux événements"
AncienActuelCoach -[#707070,thickness=2]-> ASHSAlumni : "<color:#707070>Consulte les contacts, s'inscrit aux événements"
AncienActuelPrésident -[#707070,thickness=2]-> ASHSAlumni : "<color:#707070>Consulte les contacts, s'inscrit aux événements"
ContributeurActif -[#707070,thickness=2]-> ASHSAlumni : "<color:#707070>Consulte les contacts, s'inscrit aux événements"
InvitéInscritSpontané -[#707070,thickness=2]-> ASHSAlumni : "<color:#707070>Valide son contact, s'inscrit aux événements"
Administrateur -[#707070,thickness=2]-> ASHSAlumni : "<color:#707070>Gère tous les aspects du système"
ASHSAlumni -[#707070,thickness=2]-> ServiceSMS : "<color:#707070>Envoie des invitations par SMS"
@enduml