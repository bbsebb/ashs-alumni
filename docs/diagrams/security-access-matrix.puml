@startuml security-access-matrix
!theme plain
title Matrice des droits d'accès - ASHS Alumni

!define ALLOWED <color:green><b>✓</b></color>
!define DENIED <color:red><b>✗</b></color>
!define PARTIAL <color:orange><b>◐</b></color>

package "Acteurs" {
  actor "Visiteur" as visiteur
  actor "Utilisateur\nAuthentifié" as user
  actor "Administrateur" as admin
}

package "Fonctionnalités" {
  usecase "Consulter événements publics" as UC1
  usecase "S'inscrire spontanément" as UC2
  usecase "Se connecter" as UC3
  usecase "Consulter son profil" as UC4
  usecase "Modifier son contact" as UC5
  usecase "Créer contact (statut SOUMIS)" as UC6A
  usecase "Créer contact (statut EN_ATTENTE)" as UC6B
  usecase "Modifier contact en attente/soumis" as UC7
  usecase "Modifier tout contact" as UC8
  usecase "Approuver contacts soumis" as UC9A
  usecase "Gérer les statuts" as UC9
  usecase "Créer des événements" as UC10
  usecase "Gérer les inscriptions" as UC11
  usecase "Accéder aux historiques" as UC12
  usecase "Gérer les utilisateurs" as UC13
  usecase "S'inscrire aux événements" as UC14
  usecase "Consulter contacts validés" as UC15
}

