@startuml data-model-erd
!theme plain
title Modèle de données - ASHS Alumni

entity "Contact" as contact {
  * id : UUID <<PK>>
  --
  * nom : String(50)
  * prenom : String(50)
  * genre : Enum(MASCULIN, FEMININ)
  * date_naissance : Date
  telephone : String(15)
  * email : String(255)
  * statut : Enum(EN_ATTENTE, VALIDE, NON_SOLLICITE, NON_JOIGNABLE)
  * date_creation : DateTime
  * date_modification : DateTime
  * cree_par : UUID <<FK>>
  * modifie_par : UUID <<FK>>
}

entity "Utilisateur" as utilisateur {
  * id : UUID <<PK>>
  --
  * contact_id : UUID <<FK>>
  * email : String(255)
  * mot_de_passe_hash : String(255)
  est_administrateur : Boolean = FALSE
  * date_creation : DateTime
  derniere_connexion : DateTime
  statut : Enum(ACTIF, SUSPENDU, SUPPRIME) = ACTIF
}

entity "Role" as role {
  * id : UUID <<PK>>
  --
  * nom : String(50)
  description : String(255)
  actif : Boolean = TRUE
}

entity "ContactRole" as contact_role {
  * contact_id : UUID <<FK>>
  * role_id : UUID <<FK>>
  --
  date_debut : Date
  date_fin : Date
}

entity "Evenement" as evenement {
  * id : UUID <<PK>>
  --
  * titre : String(100)
  description : Text
  * date_evenement : DateTime
  * lieu : String(255)
  places_max : Integer
  date_limite_inscription : DateTime
  * statut : Enum(BROUILLON, OUVERT, FERME, ANNULE)
  * cree_par : UUID <<FK>>
  * date_creation : DateTime
}

entity "Inscription" as inscription {
  * id : UUID <<PK>>
  --
  * evenement_id : UUID <<FK>>
  * utilisateur_id : UUID <<FK>>
  * date_inscription : DateTime
  statut : Enum(INSCRIT, ANNULE) = INSCRIT
  commentaire : String(500)
}

entity "HistoriqueContact" as historique {
  * id : UUID <<PK>>
  --
  * contact_id : UUID <<FK>>
  * action : Enum(CREATION, MODIFICATION, CHANGEMENT_STATUT)
  champs_modifies : JSON
  valeurs_avant : JSON
  valeurs_apres : JSON
  * utilisateur_id : UUID <<FK>>
  * date_action : DateTime
  adresse_ip : String(45)
}

entity "TokenValidation" as token {
  * id : UUID <<PK>>
  --
  * contact_id : UUID <<FK>>
  * token : String(255)
  * type : Enum(VALIDATION, REFUS)
  * date_creation : DateTime
  * date_expiration : DateTime
  utilise : Boolean = FALSE
  date_utilisation : DateTime
}

' Relations
utilisateur ||--|| contact : "associé à"
contact ||--o{ contact_role : "a des rôles"
role ||--o{ contact_role : "attribué à"
contact ||--o{ historique : "historisé"
contact ||--o{ token : "tokens générés"
utilisateur ||--o{ evenement : "crée"
utilisateur ||--o{ inscription : "s'inscrit"
evenement ||--o{ inscription : "reçoit des inscriptions"
utilisateur ||--o{ historique : "effectue des actions"
utilisateur ||--o{ contact : "crée/modifie"

note right of contact : "Entité centrale représentant\nune personne physique"
note right of utilisateur : "Compte d'accès à l'application\nAssociation 1:1 avec Contact validé"
note right of contact_role : "Table de liaison\nUn contact peut avoir\nplusieurs rôles"
note right of token : "Tokens pour validation SMS\nDurée de vie : 30 jours"

@enduml